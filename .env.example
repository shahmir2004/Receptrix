# ============================================
# AI PROVIDER CONFIGURATION
# ============================================
# Choose one: groq, huggingface, ollama, openai
AI_PROVIDER=groq

# GROQ (FREE - Recommended!)
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# HUGGINGFACE (FREE tier available)
# Get your free API key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# OLLAMA (FREE - runs locally)
# Install from: https://ollama.ai
OLLAMA_MODEL=llama3
OLLAMA_URL=http://localhost:11434

# OPENAI (Paid)
# Get API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ============================================
# SERVER CONFIGURATION
# ============================================
# Your public URL (ngrok URL or domain)
SERVER_URL=https://your-ngrok-url.ngrok.io
PORT=8000
DEBUG=false
# Set true in deployed environments to make /health fail on missing production config.
REQUIRE_PROD_READY=false

# ============================================
# BUSINESS CONFIGURATION
# ============================================
BUSINESS_NAME=Your Business Name
TIMEZONE=America/New_York
DEFAULT_BUSINESS_TIMEZONE=America/New_York

# ============================================
# VAPI VOICE CONFIGURATION
# ============================================
# Get these from: https://dashboard.vapi.ai
VAPI_API_KEY=your_vapi_api_key_here
VAPI_PUBLIC_KEY=your_vapi_public_key_here
VAPI_BASE_URL=https://api.vapi.ai
VAPI_WEBHOOK_SECRET=generate_a_long_random_secret
# Optional: if you create a Vapi Custom Credential for server authentication.
VAPI_SERVER_CREDENTIAL_ID=
VAPI_MODEL_PROVIDER=openai
VAPI_MODEL=gpt-4o-mini
VAPI_MAX_CALL_SECONDS=600
# Landing-page live demo call. If assistant/number IDs are blank, Receptrix
# tries the provisioned Vapi voice line for VAPI_DEMO_BUSINESS_ID.
VAPI_DEMO_BUSINESS_ID=00000000-0000-0000-0000-000000000001
VAPI_DEMO_ASSISTANT_ID=
VAPI_DEMO_PHONE_NUMBER_ID=
# Development-only escape hatch. Keep false in production.
BYPASS_BILLING_FOR_DEMO=false

# ============================================
# LEMON SQUEEZY BILLING CONFIGURATION
# ============================================
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key_here
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_MEDICAL_VARIANT_ID=your_medical_clinic_variant_id
LEMONSQUEEZY_GENERAL_VARIANT_ID=your_general_business_variant_id
LEMONSQUEEZY_WEBHOOK_SECRET=generate_a_long_random_secret
LEMONSQUEEZY_TEST_MODE=true
LEMONSQUEEZY_SUCCESS_URL=https://your-domain.com/dashboard
LEMONSQUEEZY_CANCEL_URL=https://your-domain.com/#pricing

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://supabase.com/dashboard → Project → Settings → API

# Project URL (format: https://<project-ref>.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key — safe to use in client-side code; subject to RLS
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose publicly; bypasses RLS; backend use only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# OBSERVABILITY (Phase H)
# ============================================
# Log level: DEBUG | INFO | WARNING | ERROR  (default: INFO)
LOG_LEVEL=INFO
# Log format: text (human-readable) | json (structured, for Datadog/CloudWatch)
LOG_FORMAT=text
# Allowed CORS origins (comma-separated). Leave unset for "*" (dev only).
# Example: ALLOWED_ORIGINS=https://myapp.onrender.com,https://admin.example.com
ALLOWED_ORIGINS=
# Allowed Host header values in production.
# Example: ALLOWED_HOSTS=receptrix.onrender.com,app.receptrix.com
ALLOWED_HOSTS=
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
